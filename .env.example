APP_ENV=dev

# DB backend: sqlite or postgres
DB_BACKEND=sqlite
SQLITE_PATH=./data/marginalia.db
POSTGRES_DSN=postgresql+asyncpg://marginalia:marginalia@localhost:5432/marginalia

# Storage backend: local or s3
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./data/objects

# S3 / MinIO settings (used when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=marginalia
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Task worker
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_BATCH_SIZE=4
WORKER_LEASE_SECONDS=60
WORKER_HEARTBEAT_SECONDS=20
