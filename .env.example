# .env LOCATION
#   Dev (uvicorn / pytest / CLI): project root. pydantic-settings reads
#     `.env` relative to the process CWD, so running from the repo root
#     picks up THIS file.
#   Packaged Tauri app: `<MARGINALIA_HOME>/.env` (default
#     `~/Marginalia/.env` — `C:\Users\<you>\Marginalia\.env` on Windows).
#     The Tauri shell spawns the backend with CWD=MARGINALIA_HOME so the
#     `.env`, db, library, and overlay all live in one directory.
#   LLM keys are also editable from the Settings page at runtime; those
#     writes go to `<MARGINALIA_HOME>/config_overlay.json` and override
#     this file. Use `.env` for infrastructure (DB_BACKEND, STORAGE_BACKEND,
#     MARGINALIA_HOME itself) and bootstrap LLM keys.

# Single root for all on-disk state (db, library, objects, caches,
# config_overlay.json). Defaults to ~/Marginalia. Relocate the whole
# footprint by uncommenting and pointing this elsewhere — e.g. a big
# data disk. Per-component paths under it are not separately
# configurable; symlink subdirs if you want db on SSD and library on
# spinning rust.
# MARGINALIA_HOME=

# DB backend: sqlite or postgres
DB_BACKEND=sqlite
POSTGRES_DSN=postgresql+asyncpg://marginalia:marginalia@localhost:5432/marginalia

# Storage backend: mirror, local, or s3
#   mirror = folder-tree on disk matching the user's intent (default)
#   local  = UUID-flat object pool; faster, dedup-on, less human-friendly
#   s3     = remote object storage for multi-host deployments
# mirror/local always live under <MARGINALIA_HOME>/{library,objects}.
# Relocate everything by setting MARGINALIA_HOME, or symlink a single
# subdir if you want db on SSD and library on a big disk.
STORAGE_BACKEND=mirror

# S3 / MinIO settings (used when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=marginalia
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# WebDAV knowledge-pack sync (optional)
# Publishes immutable metadata snapshots plus sha256-addressed blobs.
# This is not a live MARGINALIA_HOME sync and does not upload sqlite/cache/runtime.
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_REMOTE_PATH=/marginalia
WEBDAV_AUTO_SYNC_ENABLED=false
WEBDAV_AUTO_SYNC_INTERVAL_MINUTES=60

# Task worker
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_BATCH_SIZE=4
WORKER_LEASE_SECONDS=60
WORKER_HEARTBEAT_SECONDS=20

# Automatic file lifecycle transitions. false keeps entries active unless
# the user manually changes lifecycle; true lets the worker demote/archive
# inactive entries on a schedule.
AUTO_LIFECYCLE_ENABLED=false

# ===== Agent token budgets =====
# Per-call max_tokens for plan / execute phases. Defaults sized for
# gpt-4o-class models. Bump for long-context backends — e.g. DeepSeek-V3
# can return 64K+ in one shot, so 2048 will silently truncate answers.
# AGENT_PLAN_MAX_TOKENS=1024
# AGENT_EXECUTE_MAX_TOKENS=2048

# Deterministic read_files result compression. This does not call an LLM and
# does not change stored ingest output; it only trims large read_files tool
# results before they are sent back to the chat model. Omitted regions include
# reopen anchors and can be fetched with read_files compress=false.
# READ_COMPRESSION_ENABLED=true
# READ_COMPRESSION_MIN_CHARS=12000
# READ_COMPRESSION_TARGET_CHARS=8000
# READ_COMPRESSION_CONTEXT_CHARS=220

# Parallel LLM calls inside one ingest task. Applies to long text/PDF
# chunk indexing and scanned-PDF OCR pages. Raise for high-throughput
# providers; lower to 1-2 if you hit rate limits.
# LLM_INGEST_CONCURRENCY=10

# ===== LLM defaults =====
# Per-profile overrides (LLM_<PROFILE>_*) inherit from LLM_DEFAULT_* per-field.
# PROVIDER:
#   openai            = OpenAI proper (supports strict json_schema)
#   openai-compatible = DeepSeek / Together / Groq / vllm / ollama. Same wire
#                       format; the adapter falls back to json_object + a
#                       schema-in-prompt instruction since these endpoints
#                       reject OpenAI's strict json_schema.
#   anthropic         = Anthropic Messages API
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_API_KEY=
LLM_DEFAULT_BASE_URL=
LLM_DEFAULT_MODEL=gpt-4o-mini
# Max provider calls per second for this provider/base/model. If several
# profiles resolve to the same model endpoint, the lowest matching TPS wins.
# LLM_DEFAULT_TPS=10

# ===== Per-profile LLM overrides (optional) =====
# Profiles: chat, reflect, ingest, vision.
# LLM_CHAT_PROVIDER=
# LLM_CHAT_API_KEY=
# LLM_CHAT_BASE_URL=
# LLM_CHAT_MODEL=
# LLM_CHAT_TPS=10

# LLM_REFLECT_PROVIDER=
# LLM_REFLECT_API_KEY=
# LLM_REFLECT_BASE_URL=
# LLM_REFLECT_MODEL=
# LLM_REFLECT_TPS=10

# LLM_INGEST_PROVIDER=
# LLM_INGEST_API_KEY=
# LLM_INGEST_BASE_URL=
# LLM_INGEST_MODEL=
# LLM_INGEST_TPS=10

# LLM_VISION_PROVIDER=
# LLM_VISION_API_KEY=
# LLM_VISION_BASE_URL=
# LLM_VISION_MODEL=
# LLM_VISION_TPS=10

# Embedded images inside DOCX/PPTX can be described at ingest and queried
# with read_files(question=...). Disable or lower caps if VLM cost matters.
# DOCUMENT_VISION_ENABLED=true
# DOCUMENT_VISION_MAX_IMAGES=20
# DOCUMENT_VISION_QUESTION_MAX_IMAGES=5
# DOCUMENT_VISION_MIN_IMAGE_BYTES=2048
# DOCUMENT_VISION_MIN_IMAGE_DIMENSION=32
# DOCUMENT_VISION_MIN_IMAGE_AREA=4096

# ===== Optional semantic recall =====
# Embedding credentials are separate from LLM_* profiles. They are never
# inferred from chat, vision, or ingest keys.
# EMBEDDING_PROVIDER=openai-compatible
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_TPS=10
# EMBEDDING_BATCH_SIZE=10
#
# Build an index with:
#   marginalia eval build-semantic-index <dataset>
# Then enable semantic candidates in recall_knowledge:
# SEMANTIC_RECALL_ENABLED=false
# SEMANTIC_RECALL_LIMIT=100
# SEMANTIC_INDEX_BACKEND=auto       # auto, file, sqlite-vec

# ===== Optional rerank =====
# Rerank is a second-stage retrieval refinement over recalled candidates.
# It also uses its own credential; no LLM_* key is reused implicitly.
# RERANK_ENABLED=false
# RERANK_API_KEY=
# RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
# RERANK_MODEL=qwen3-rerank
# RERANK_TPS=10
# RERANK_BATCH_SIZE=100
# RERANK_TOP_N=80
# RERANK_MAX_DOC_CHARS=1800
# RERANK_CONCURRENCY=10
# EVIDENCE_SELECTION=quota          # quota or rerank
